df.data <- read.csv("DATASET.csv")
summary(df.data)
df.data <- subset(df.data, STATE != 0)
df.data$STATE <- fips(df.data$STATE, to ='Abbreviation')
df.data <- subset(df.data, AGE.REFP != 999)
df.data <- subset(df.data, AGE.SPOUSE != 999)
df.data <- subset(df.data, SALARY != 9999998.00)
df.data <- subset(df.data, SALARY != 9999999.00)
df.data <- subset(df.data, SALARY != 1000000.0)
df.data <- subset(df.data, EDU.FATHER != 99)
df.data <- subset(df.data, EDU.MOTHER != 99)
df.data <- subset(df.data, RACE.SPOUSE != 9)
df.data <- subset(df.data, RELIGION.SPOUSE != 99)
df.data <- subset(df.data, RACE.REFP != 9)
df.data <- subset(df.data, RELIGION.REFP != 99)
df.data$lnSALARY <- ifelse(df.data$SALARY != 0, log(df.data$SALARY), df.data$SALARY)
df.data$SAMESEX <- ifelse(df.data$SEX.REFP == df.data$SEX.SPOUSE, 1, 0)
summary(df.data)
df.data$x40OROLDER.REFP <- ifelse(df.data$AGE.REFP >= 40, 1, 0)
df.data$x50OROLDER.REFP <- ifelse(df.data$AGE.REFP >= 50, 1, 0)
df.data$x60OROLDER.REFP <- ifelse(df.data$AGE.REFP >= 60, 1, 0)
df.data$x40OROLDER.SPOUSE <- ifelse(df.data$AGE.SPOUSE >= 40, 1, 0)
df.data$x50OROLDER.SPOUSE <- ifelse(df.data$AGE.SPOUSE >= 50, 1, 0)
df.data$x60OROLDER.SPOUSE <- ifelse(df.data$AGE.SPOUSE >= 60, 1, 0)
summary(df.data)
reg.efe.state.salary <- plm(NUM.CHILD ~ SALARY,
data = df.data,
index = c("STATE"),
model = "within")
summary(reg.efe.state.salary)
fixef(reg.efe.state.salary)
reg.efe.state.lnsalary <- plm(NUM.CHILD ~ lnSALARY,
data = df.data,
index = c("STATE"),
model = "within")
summary(reg.efe.state.lnsalary)
fixef(reg.efe.state.lnsalary)
reg.efe.state1 <- plm(NUM.CHILD ~ AGE.REFP+SEX.REFP+AGE.SPOUSE+SEX.SPOUSE+lnSALARY+EDU.FATHER+EDU.MOTHER+RACE.SPOUSE+RELIGION.SPOUSE+RACE.REFP+RELIGION.REFP+SAMESEX+x40OROLDER.REFP+x50OROLDER.REFP+x60OROLDER.REFP+x40OROLDER.SPOUSE+x50OROLDER.SPOUSE+x60OROLDER.SPOUSE+AGE.REFP*x40OROLDER.REFP+AGE.REFP*x50OROLDER.REFP+AGE.REFP*x60OROLDER.REFP+AGE.SPOUSE*x40OROLDER.SPOUSE+AGE.SPOUSE*x50OROLDER.SPOUSE+AGE.SPOUSE*x60OROLDER.SPOUSE,
data = df.data,
index = c("STATE"),
model = "within")
summary(reg.efe.state1)
fixef(reg.efe.state1)
reg.efe.state.excluASBandINT <- plm(NUM.CHILD ~ AGE.REFP+SEX.REFP+AGE.SPOUSE+SEX.SPOUSE+lnSALARY+EDU.FATHER+RELIGION.SPOUSE+RACE.REFP+RELIGION.REFP+SAMESEX,
data = df.data,
index = c("STATE"),
model = "within")
summary(reg.efe.state.excluASBandINT)
fixef(reg.efe.state.excluASBandINT)
reg.efe.state.excluINT <- plm(NUM.CHILD ~ AGE.REFP+SEX.REFP+AGE.SPOUSE+SEX.SPOUSE+lnSALARY+EDU.FATHER+RELIGION.SPOUSE+RACE.REFP+RELIGION.REFP+SAMESEX+x40OROLDER.REFP+x60OROLDER.REFP+x40OROLDER.SPOUSE+x50OROLDER.SPOUSE+x60OROLDER.SPOUSE,
data = df.data,
index = c("STATE"),
model = "within")
summary(reg.efe.state.excluINT)
fixef(reg.efe.state.excluINT)
reg.efe.state2 <- plm(NUM.CHILD ~ AGE.REFP+SEX.REFP+AGE.SPOUSE+SEX.SPOUSE+lnSALARY+EDU.FATHER+RELIGION.SPOUSE+RACE.REFP+RELIGION.REFP+SAMESEX+x40OROLDER.REFP+x60OROLDER.REFP+x40OROLDER.SPOUSE+x50OROLDER.SPOUSE+x60OROLDER.SPOUSE+AGE.REFP*x40OROLDER.REFP+AGE.REFP*x60OROLDER.REFP+AGE.SPOUSE*x40OROLDER.SPOUSE+AGE.SPOUSE*x50OROLDER.SPOUSE+AGE.SPOUSE*x60OROLDER.SPOUSE,
data = df.data,
index = c("STATE"),
model = "within")
summary(reg.efe.state2)
efe <- fixef(reg.efe.state2)
efe
df.state <- sort(unique(df.data$STATE))
lstate <- length(df.state)
for(i in 1:lstate) {
currentStateEstimate <- efe[[i]] +
reg.efe.state2$coefficients[[1]] * mean(df.data[df.data$STATE == df.state[i], 'AGE.REFP']) +
reg.efe.state2$coefficients[[2]] * mean(df.data[df.data$STATE == df.state[i], 'SEX.REFP']) +
reg.efe.state2$coefficients[[3]] * mean(df.data[df.data$STATE == df.state[i], 'AGE.SPOUSE']) +
reg.efe.state2$coefficients[[4]] * mean(df.data[df.data$STATE == df.state[i], 'SEX.SPOUSE']) +
reg.efe.state2$coefficients[[5]] * mean(df.data[df.data$STATE == df.state[i], 'lnSALARY']) +
reg.efe.state2$coefficients[[6]] * mean(df.data[df.data$STATE == df.state[i], 'EDU.FATHER']) +
reg.efe.state2$coefficients[[7]] * mean(df.data[df.data$STATE == df.state[i], 'RELIGION.SPOUSE']) +
reg.efe.state2$coefficients[[8]] * mean(df.data[df.data$STATE == df.state[i], 'RACE.REFP']) +
reg.efe.state2$coefficients[[9]] * mean(df.data[df.data$STATE == df.state[i], 'RELIGION.REFP']) +
reg.efe.state2$coefficients[[10]] * mean(df.data[df.data$STATE == df.state[i], 'SAMESEX']) +
reg.efe.state2$coefficients[[11]] * ifelse(mean(df.data[df.data$STATE == df.state[i], 'AGE.REFP']) >= 40, 1, 0) +
reg.efe.state2$coefficients[[12]] * ifelse(mean(df.data[df.data$STATE == df.state[i], 'AGE.REFP']) >= 60, 1, 0) +
reg.efe.state2$coefficients[[13]] * ifelse(mean(df.data[df.data$STATE == df.state[i], 'AGE.SPOUSE']) >= 40, 1, 0) +
reg.efe.state2$coefficients[[14]] * ifelse(mean(df.data[df.data$STATE == df.state[i], 'AGE.SPOUSE']) >= 50, 1, 0) +
reg.efe.state2$coefficients[[15]] * ifelse(mean(df.data[df.data$STATE == df.state[i], 'AGE.SPOUSE']) >= 60, 1, 0) +
reg.efe.state2$coefficients[[16]] *
mean(df.data[df.data$STATE == df.state[i], 'AGE.REFP']) *
ifelse(mean(df.data[df.data$STATE == df.state[i], 'AGE.REFP']) >= 40, 1, 0) +
reg.efe.state2$coefficients[[17]] *
mean(df.data[df.data$STATE == df.state[i], 'AGE.REFP']) *
ifelse(mean(df.data[df.data$STATE == df.state[i], 'AGE.REFP']) >= 60, 1, 0) +
reg.efe.state2$coefficients[[18]] *
mean(df.data[df.data$STATE == df.state[i], 'AGE.SPOUSE']) *
ifelse(mean(df.data[df.data$STATE == df.state[i], 'AGE.SPOUSE']) >= 40, 1, 0) +
reg.efe.state2$coefficients[[19]] *
mean(df.data[df.data$STATE == df.state[i], 'AGE.SPOUSE']) *
ifelse(mean(df.data[df.data$STATE == df.state[i], 'AGE.SPOUSE']) >= 50, 1, 0) +
reg.efe.state2$coefficients[[20]] *
mean(df.data[df.data$STATE == df.state[i], 'AGE.SPOUSE']) *
ifelse(mean(df.data[df.data$STATE == df.state[i], 'AGE.SPOUSE']) >= 60, 1, 0)
cat(paste('Our model predicts that the mean individual from',
fips(df.state[i], to ='Name'),
'will have',
round(currentStateEstimate, digits = 5),
'children.', '\n'))
}
export_summs(reg.efe.state.salary,reg.efe.state.lnsalary, reg.efe.state.excluASBandINT, reg.efe.state.excluINT, reg.efe.state2, scale = TRUE, model.names = c("Salary Model", "lnSalary Model", "All Model Excluding Age Stratification and Interaction Terms", "All Model Excluding Interaction Terms", "All SS Coefficient Model"))
export_summs(reg.efe.state.salary,reg.efe.state.lnsalary, reg.efe.state.excluASBandINT, reg.efe.state.excluINT, reg.efe.state2, scale = TRUE, model.names = c("Salary Model", "lnSalary Model", "All Model Excluding Age Stratification and Interaction Terms", "All Model Excluding Interaction Terms", "All SS Coefficient Model"), digits = 3)
export_summs(reg.efe.state.salary,reg.efe.state.lnsalary, reg.efe.state.excluASBandINT, reg.efe.state.excluINT, reg.efe.state2, scale = TRUE, model.names = c("Salary Model", "lnSalary Model", "All Model Excluding Age Stratification and Interaction Terms", "All Model Excluding Interaction Terms", "All SS Coefficient Model"), digits = 4)
export_summs(reg.efe.state.salary,reg.efe.state.lnsalary, reg.efe.state.excluASBandINT, reg.efe.state.excluINT, reg.efe.state2, scale = TRUE, model.names = c("Salary Model", "lnSalary Model", "All Model Excluding Age Stratification and Interaction Terms", "All Model Excluding Interaction Terms", "All SS Coefficient Model"), digits = 3)
export_summs(reg.efe.state.salary,reg.efe.state.lnsalary, reg.efe.state.excluASBandINT, reg.efe.state.excluINT, reg.efe.state2, scale = TRUE, model.names = c("Salary Model", "lnSalary Model", "All Model Excluding Age Strata and Interaction Terms", "All Model Excluding Interaction Terms", "All SS Coefficient Model"), digits = 3)
export_summs(reg.efe.state.salary,reg.efe.state.lnsalary, reg.efe.state.excluASBandINT, reg.efe.state.excluINT, reg.efe.state2, scale = TRUE, model.names = c("Salary Model", "lnSalary Model", "All Model Excluding Age Strata and Interaction Terms", "All Model Excluding Interaction Terms", "All SS Coefficient Model"), digits = 3, to.file = "pdf", file.name = "Model Comparison Table")
export_summs(reg.efe.state.salary,reg.efe.state.lnsalary, reg.efe.state.excluASBandINT, reg.efe.state.excluINT, reg.efe.state2, scale = TRUE, model.names = c("Salary Model", "lnSalary Model", "All Model Excluding Age Strata and Interaction Terms", "All Model Excluding Interaction Terms", "All SS Coefficient Model"), digits = 3, to.file = "pdf", file.name = "ModelComparisonTable")
anova(reg.efe.state.salary,reg.efe.state.lnsalary, reg.efe.state.excluASBandINT, reg.efe.state.excluINT, reg.efe.state2)
export_summs(reg.efe.state.salary,reg.efe.state.lnsalary, reg.efe.state.excluASBandINT, reg.efe.state.excluINT, reg.efe.state2, scale = TRUE, model.names = c("Salary Model", "lnSalary Model", "All Model Excluding Age Strata and Interaction Terms", "All Model Excluding Interaction Terms", "All SS Coefficient Model"), digits = 3)
